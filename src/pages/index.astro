---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { email, phone, addressStreet, addressCity, addressPostal, hours } from "../data/contact";

import koncert from "../assets/images/koncert.jpg";
import bajka from "../assets/images/bajka.jpg";
import festyn from "../assets/images/festyn.jpg";
import integracja from "../assets/images/integracja.jpg";
import przedszkole from "../assets/images/przedszkole-wspolpraca.jpg";
import zajecia from "../assets/images/zajecia-manualne.jpg";
---

<Layout
  title="Agencja Artystyczna Pro Arte"
  description="Profesjonalna oprawa artystyczna imprez dla dzieci – koncerty autorskie, muzyczne bajki, imprezy integracyjne i festyny. Działamy od 2017 roku w okolicach Wołomina."
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-background"></div>
    <div class="container hero-content">
      <div class="hero-text fade-in-up">
        <h1>Oprawa artystyczna imprez dla dzieci</h1>
        <p class="hero-subtitle">
          Zajmujemy się oprawą artystyczną imprez dla dzieci. Każde spotkanie z
          publicznością jest dla nas niesłychanie ważne.
        </p>
        <p class="hero-subtitle">
          Wśród naszych propozycji są koncerty autorskie dla dorosłych i dla
          dzieci, bajki, programy artystyczne na imprezy integracyjne, festyny,
          oryginalne i zaskakujące scenariusze - czyli wszystko, co jest
          potrzebne, aby impreza się udała!
        </p>
        <p class="hero-subtitle">
          O sukcesie artystycznym imprezy decyduje świetna konferansjerka,
          interesujący program dostosowany do charakteru spotkania, znakomici
          artyści, odpowiednia muzyka. Możemy to wszystko Państwu zapewnić!
        </p>
        <div class="hero-buttons">
          <a href="#oferta" class="btn btn-primary">Zobacz ofertę</a>
          <a href="#kontakt" class="btn btn-secondary">Skontaktuj się</a>
        </div>
      </div>
      <div class="hero-stats">
        <div class="stat-item fade-in" style="animation-delay: 0.2s;">
          <span class="stat-number" data-target="500">0</span>
          <span class="stat-label">Imprez</span>
        </div>
        <div class="stat-item fade-in" style="animation-delay: 0.4s;">
          <span class="stat-number" data-target="1000">0</span>
          <span class="stat-label">Występów</span>
        </div>
        <div class="stat-item fade-in" style="animation-delay: 0.6s;">
          <span class="stat-number" data-target="50000">0</span>
          <span class="stat-label">Widzów</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Oferta Section -->
  <section id="oferta" class="oferta">
    <div class="container">
      <h2 class="section-title">Nasza Oferta</h2>
      <p class="section-subtitle">
        Różnorodne programy artystyczne dostosowane do charakteru wydarzenia
      </p>

      <div class="offer-grid">
        <div class="offer-card">
          <div class="offer-icon">🎭</div>
          <h3>Koncerty Autorskie</h3>
          <p>
            Autorskie programy muzyczne dla dzieci i dorosłych. Unikalne
            przedstawienia, które łączą muzykę z opowieścią i interakcją z
            publicznością.
          </p>
          <ul class="offer-features">
            <li>✓ Czas trwania: 45-90 min</li>
            <li>✓ Dla dzieci i dorosłych</li>
            <li>✓ Interaktywna forma</li>
            <li>✓ Profesjonalni artyści</li>
          </ul>
        </div>

        <div class="offer-card featured">
          <div class="badge">Najpopularniejsze</div>
          <div class="offer-icon">📚</div>
          <h3>Muzyczne Bajki</h3>
          <p>
            Bajki z oprawą muzyczną, które zachwycają najmłodszych. Połączenie
            storytellingu z żywą muzyką tworzy niezapomniane wrażenia.
          </p>
          <ul class="offer-features">
            <li>✓ Czas trwania: 30-45 min</li>
            <li>✓ Dla przedszkolaków i szkół</li>
            <li>✓ Edukacyjna treść</li>
            <li>✓ Kolorowa scenografia</li>
          </ul>
        </div>

        <div class="offer-card">
          <div class="offer-icon">🎉</div>
          <h3>Imprezy Integracyjne</h3>
          <p>
            Programy artystyczne na festyny, imprezy szkolne i wydarzenia
            firmowe. Dopasowane do charakteru spotkania i oczekiwań
            organizatora.
          </p>
          <ul class="offer-features">
            <li>✓ Elastyczny czas trwania</li>
            <li>✓ Konferansjerka</li>
            <li>✓ Oryginalne scenariusze</li>
            <li>✓ Pełna oprawa artystyczna</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Artyści Section -->
  <section id="artysci" class="artysci">
    <div class="container">
      <h2 class="section-title">Nasi Artyści</h2>
      <p class="section-subtitle">
        Znakomici wykonawcy i konferansjerzy, którzy zapewnią sukces Państwa
        imprezy
      </p>

      <div class="artists-grid">
        <div class="artist-card">
          <div class="artist-image">
            <i class="fas fa-microphone-alt artist-icon"></i>
          </div>
          <h3>Moderatorka</h3>
          <p class="artist-role">Prowadzenie imprez</p>
          <p>
            Doświadczona konferansjerka, która potrafi wciągnąć publiczność w
            zabawę i stworzyć wyjątkową atmosferę na każdym wydarzeniu.
          </p>
        </div>

        <div class="artist-card">
          <div class="artist-image">
            <i class="fas fa-music artist-icon"></i>
          </div>
          <h3>Muzycy</h3>
          <p class="artist-role">Oprawa muzyczna</p>
          <p>
            Profesjonalni muzycy z wieloletnim doświadczeniem w pracy z dziećmi
            i młodzieżą. Gwarantujemy najwyższą jakość wykonania.
          </p>
        </div>

        <div class="artist-card">
          <div class="artist-image">
            <i class="fas fa-theater-masks artist-icon"></i>
          </div>
          <h3>Aktorzy</h3>
          <p class="artist-role">Scenariusze autorskie</p>
          <p>
            Utalentowani aktorzy, którzy wcielają się w różne role i tworzą
            niezapomniane przedstawienia dla najmłodszych widzów.
          </p>
        </div>

        <div class="artist-card">
          <div class="artist-image">
            <i class="fas fa-video artist-icon"></i>
          </div>
          <h3>Reżyserzy</h3>
          <p class="artist-role">Scenariusze na miarę</p>
          <p>
            Kreatywni twórcy, którzy przygotowują oryginalne i zaskakujące
            scenariusze dostosowane do charakteru wydarzenia.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Galeria Section -->
  <section id="galeria" class="galeria">
    <div class="container">
      <h2 class="section-title">Galeria</h2>
      <p class="section-subtitle">
        Zobacz jak wyglądają nasze występy i imprezy
      </p>

      <div class="gallery-grid">
        <div class="gallery-item">
          <div class="gallery-image-wrapper">
            <Image
              width={800}
              height={600}
              src={koncert}
              alt="Koncert w szkole"
            />
          </div>
          <p>Koncert w szkole</p>
        </div>
        <div class="gallery-item">
          <div class="gallery-image-wrapper">
            <Image
              width={800}
              height={600}
              src={bajka}
              alt="Muzyczna bajka"
              loading="lazy"
            />
          </div>
          <p>Muzyczna bajka</p>
        </div>
        <div class="gallery-item">
          <div class="gallery-image-wrapper">
            <Image
              width={800}
              height={600}
              src={festyn}
              alt="Festyn szkolny"
              loading="lazy"
            />
          </div>
          <p>Festyn szkolny</p>
        </div>
        <div class="gallery-item">
          <div class="gallery-image-wrapper">
            <Image
              width={800}
              height={600}
              src={integracja}
              alt="Impreza integracyjna"
              loading="lazy"
            />
          </div>
          <p>Impreza integracyjna</p>
        </div>
        <div class="gallery-item">
          <div class="gallery-image-wrapper">
            <Image
              width={800}
              height={600}
              src={przedszkole}
              alt="Występ dla przedszkolaków"
              loading="lazy"
            />
          </div>
          <p>Występ dla przedszkolaków</p>
        </div>
        <div class="gallery-item">
          <div class="gallery-image-wrapper">
            <Image
              width={800}
              height={600}
              src={zajecia}
              alt="Zajęcia manualne"
              loading="lazy"
            />
          </div>
          <p>Zajęcia manualne</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cennik Section -->
  <section id="cennik" class="cennik">
    <div class="container">
      <h2 class="section-title">Cennik</h2>
      <p class="section-subtitle">
        Przejrzyste ceny dostosowane do Państwa potrzeb i budżetu
      </p>

      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-header">
            <h3>Pakiet Podstawowy</h3>
            <div class="price">
              <span class="price-amount">1500</span>
              <span class="price-currency">zł</span>
            </div>
          </div>
          <ul class="pricing-features">
            <li>✓ Występ 30-45 minut</li>
            <li>✓ Do 100 widzów</li>
            <li>✓ 2-3 artystów</li>
            <li>✓ Nagłośnienie podstawowe</li>
            <li>✓ Prosty scenariusz</li>
          </ul>
          <a href="#kontakt" class="btn btn-secondary">Wybierz pakiet</a>
        </div>

        <div class="pricing-card featured">
          <div class="badge">Polecamy</div>
          <div class="pricing-header">
            <h3>Pakiet Rozszerzony</h3>
            <div class="price">
              <span class="price-amount">2500</span>
              <span class="price-currency">zł</span>
            </div>
          </div>
          <ul class="pricing-features">
            <li>✓ Występ 45-60 minut</li>
            <li>✓ Do 200 widzów</li>
            <li>✓ 4-5 artystów</li>
            <li>✓ Profesjonalne nagłośnienie</li>
            <li>✓ Konferansjerka</li>
            <li>✓ Autorski scenariusz</li>
            <li>✓ Oprawa multimedialna</li>
          </ul>
          <a href="#kontakt" class="btn btn-primary">Wybierz pakiet</a>
        </div>

        <div class="pricing-card">
          <div class="pricing-header">
            <h3>Pakiet Premium</h3>
            <div class="price">
              <span class="price-amount">4000</span>
              <span class="price-currency">zł</span>
            </div>
          </div>
          <ul class="pricing-features">
            <li>✓ Występ 60-90 minut</li>
            <li>✓ Bez limitu widzów</li>
            <li>✓ 6+ artystów</li>
            <li>✓ Nagłośnienie koncertowe</li>
            <li>✓ Konferansjerka</li>
            <li>✓ Pełna oprawa artystyczna</li>
            <li>✓ Oryginalna scenografia</li>
            <li>✓ Dokumentacja foto/wideo</li>
          </ul>
          <a href="#kontakt" class="btn btn-secondary">Wybierz pakiet</a>
        </div>
      </div>

      <div class="pricing-note">
        <p>
          💡 <strong>Uwaga:</strong> Ceny są orientacyjne i mogą się różnić w zależności
          od lokalizacji, rodzaju imprezy i dodatkowych wymagań. Skontaktuj się z
          nami, aby otrzymać indywidualną wycenę.
        </p>
      </div>
    </div>
  </section>

  <!-- Kontakt Section -->
  <section id="kontakt" class="kontakt">
    <div class="container">
      <h2 class="section-title">Skontaktuj się z nami</h2>
      <p class="section-subtitle">
        Chętnie odpowiemy na wszystkie pytania i przygotujemy ofertę
      </p>

      <div class="contact-wrapper">
        <div class="contact-info">
          <h3>Dane kontaktowe</h3>
          <div class="contact-item">
            <span class="contact-icon">📧</span>
            <div>
              <strong>Email</strong>
              <p><a href={`mailto:${email}`}>{email}</a></p>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-icon">📱</span>
            <div>
              <strong>Telefon</strong>
              <p><a href={`tel:${phone.replace(/\s/g, "")}`}>{phone}</a></p>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-icon">📍</span>
            <div>
              <strong>Adres</strong>
              <p>{addressStreet}, {addressCity}<br />{addressPostal} {addressCity}</p>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-icon">⏰</span>
            <div>
              <strong>Godziny pracy</strong>
              <p>{hours}</p>
            </div>
          </div>
        </div>

        <div class="contact-form-wrapper">
          <form
            action="https://formspree.io/f/xrekzrnq"
            method="POST"
            class="contact-form"
          >
            <div class="form-group">
              <label for="name">Imię i nazwisko *</label>
              <input type="text" id="name" name="name" required />
            </div>

            <div class="form-group">
              <label for="organization">Nazwa placówki/firmy *</label>
              <input type="text" id="organization" name="organization" required />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required />
              </div>

              <div class="form-group">
                <label for="phone">Telefon</label>
                <input type="tel" id="phone" name="phone" />
              </div>
            </div>

            <div class="form-group">
              <label for="event-type">Rodzaj imprezy</label>
              <select id="event-type" name="event-type">
                <option value="">Wybierz...</option>
                <option value="concert">Koncert autorski</option>
                <option value="fairytale">Muzyczna bajka</option>
                <option value="integration">Impreza integracyjna</option>
                <option value="festival">Festyn</option>
                <option value="other">Inne</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Wiadomość *</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Wyślij wiadomość</button>
          </form>
          <div id="thank-you-message" class="thank-you-message" hidden>
            Dziękujemy za kontakt! Odezwiemy się wkrótce.
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      var(--color-primary) 0%,
      var(--color-secondary) 100%
    );
  }

  .hero-background {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        circle at 20% 50%,
        rgba(255, 255, 255, 0.1) 0%,
        transparent 50%
      ),
      radial-gradient(
        circle at 80% 80%,
        rgba(255, 255, 255, 0.1) 0%,
        transparent 50%
      );
    animation: float 20s ease-in-out infinite;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    color: white;
    padding: var(--spacing-sm) var(--spacing-sm);
  }

  .hero-text {
    max-width: 800px;
    margin-bottom: var(--spacing-lg);
  }

  .hero h1 {
    color: white;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: var(--spacing-sm);
    line-height: 1.7;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: var(--spacing-md);
  }

  .hero-buttons .btn-secondary {
    background: white;
    color: var(--color-primary);
    border: none;
  }

  .hero-buttons .btn-secondary:hover {
    background: var(--color-bg);
    color: var(--color-primary);
  }

  .hero-stats {
    display: flex;
    gap: var(--spacing-lg);
    flex-wrap: wrap;
    margin-top: var(--spacing-lg);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--spacing-md);
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border-radius: var(--radius-md);
    min-width: 150px;
  }

  .stat-number {
    font-size: 3rem;
    font-weight: 900;
    font-family: var(--font-heading);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  /* Section Titles */
  .section-title {
    text-align: center;
    margin-bottom: var(--spacing-sm);
  }

  .section-subtitle {
    text-align: center;
    font-size: 1.1rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto var(--spacing-lg);
  }

  /* Oferta Section */
  .oferta {
    background: var(--color-bg-alt);
    padding-top: var(--spacing-lg);
  }

  .offer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .offer-card {
    background: white;
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    transition: all 0.3s ease;
    position: relative;
  }

  .offer-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .offer-card.featured {
    border: 3px solid var(--color-primary);
  }

  .badge {
    position: absolute;
    top: -12px;
    right: 20px;
    background: var(--color-primary);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .offer-icon {
    font-size: 4rem;
    margin-bottom: var(--spacing-sm);
  }

  .offer-card h3 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-sm);
  }

  .offer-features {
    list-style: none;
    margin-top: var(--spacing-md);
  }

  .offer-features li {
    padding: 0.5rem 0;
    color: var(--color-text-light);
    border-bottom: 1px solid var(--color-border);
  }

  .offer-features li:last-child {
    border-bottom: none;
  }

  /* Artyści Section */
  .artists-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .artist-card {
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: all 0.3s ease;
  }

  .artist-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }

  .artist-image {
    width: 100%;
    height: 280px;
    background: linear-gradient(
      135deg,
      var(--color-secondary) 0%,
      var(--color-primary) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .artist-icon {
    font-size: 4rem;
    color: white;
  }

  .artist-card h3 {
    padding: var(--spacing-sm) var(--spacing-md) 0;
    color: var(--color-text);
  }

  .artist-role {
    padding: 0 var(--spacing-md);
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .artist-card p:last-child {
    padding: var(--spacing-sm) var(--spacing-md) var(--spacing-md);
  }

  /* Galeria Section */
  .galeria {
    background: var(--color-bg-alt);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .gallery-item {
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: all 0.3s ease;
    background: white;
  }

  .gallery-item:hover {
    transform: scale(1.05);
    box-shadow: var(--shadow-lg);
  }

  .gallery-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .gallery-image-wrapper img {
    height: 100%;
  }

  .gallery-item p {
    padding: var(--spacing-sm) var(--spacing-md);
    font-weight: 800;
    text-align: center;
  }

  /* Cennik Section */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .pricing-card {
    background: white;
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    box-shadow: var(--shadow-md);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .pricing-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }

  .pricing-card.featured {
    border: 3px solid var(--color-primary);
    transform: scale(1.05);
  }

  .pricing-card.featured:hover {
    transform: scale(1.08) translateY(-5px);
  }

